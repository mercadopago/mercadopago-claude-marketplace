{
  "description": "Mercado Pago developer plugin hooks",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/validate_mp_credentials.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill(mercadopago:payment|mercadopago:card-payment|mercadopago:wallet|mercadopago:status-screen)",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "A Checkout Bricks skill was just used. After completing the full implementation, run mcp__mercadopago__quality_checklist for the brick used, then mcp__mercadopago__quality_evaluation. Both must complete successfully before you finish."
          }
        ]
      }
    ]
  }
}
